		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.101.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"date-fns": "^4.1.0",
