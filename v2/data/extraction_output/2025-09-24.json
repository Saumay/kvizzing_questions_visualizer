    "has_media": false,
    "is_session_question": false,
    "session_quizmaster": null,
    "session_theme": null,
    "session_question_number": null,
    "answer_text": "The meridian facing Earth — the center line of the face of the moon visible from Earth (since the moon is tidally locked, this is a fixed, natural choice)",
